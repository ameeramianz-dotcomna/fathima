        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap');
        @keyframes abDrift { 0%,100%{transform:translate(0,0)} 50%{transform:translate(16px,-16px)} }
        @keyframes abBadgeBob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
        @keyframes abSpin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
        @keyframes abSpinRev { from{transform:rotate(0deg)} to{transform:rotate(-360deg)} }
        @keyframes abPulse {
          0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 0 0 rgba(184,151,90,0.5)}
          50%{opacity:0.7;transform:scale(0.8);box-shadow:0 0 0 5px rgba(184,151,90,0)}
        }
        .ab-ring-spin { animation: abSpin 30s linear infinite; }
        .ab-ring2-spin { animation: abSpinRev 20s linear infinite; }
        .ab-badge-bob { animation: abBadgeBob 5s ease-in-out infinite; }
        .ab-float-bob { animation: abBadgeBob 6s ease-in-out 1.5s infinite; }
        .ab-img-hover:hover { transform: scale(1.02); }
      </style><section id="about" style="width: 100%; background: rgb(255, 255, 255); padding: 80px 24px 96px; position: relative; overflow: hidden; font-family: &quot;DM Sans&quot;, sans-serif;"><div style="position: absolute; inset: 0px; pointer-events: none;"><div style="position: absolute; inset: 0px; background-image: repeating-linear-gradient(-55deg, transparent, transparent 44px, rgba(68, 101, 89, 0.02) 44px, rgba(68, 101, 89, 0.02) 45px);"></div><div style="position: absolute; top: 0px; right: 0px; width: 220px; height: 260px; background-image: radial-gradient(circle, rgba(68, 101, 89, 0.13) 1.2px, transparent 1.2px); background-size: 20px 20px; opacity: 0.6;"></div><div style="position: absolute; bottom: -120px; left: -80px; width: 520px; height: 520px; border-radius: 50%; background: radial-gradient(circle, rgba(68, 101, 89, 0.07) 0%, transparent 70%); animation: 16s ease-in-out 0s infinite normal none running abDrift;"></div><div style="position: absolute; top: -160px; right: -120px; width: 440px; height: 440px; border-radius: 50%; background: radial-gradient(circle, rgba(184, 151, 90, 0.06) 0%, transparent 70%); animation: 12s ease-in-out 0s infinite reverse none running abDrift;"></div></div><div style="position: relative; z-index: 2; max-width: 1100px; margin: 0px auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 72px; align-items: center;"><div><div style="display: inline-flex; align-items: center; gap: 10px; font-size: 10.5px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(68, 101, 89); background: rgb(238, 245, 241); padding: 8px 18px; border-radius: 100px; border: 1px solid rgba(68, 101, 89, 0.18); margin-bottom: 22px; opacity: 0; transform: translateY(20px); transition: opacity 0.6s, transform 0.6s;"><span style="width: 6px; height: 6px; border-radius: 50%; background: rgb(184, 151, 90); display: inline-block; animation: 2.2s ease 0s infinite normal none running abPulse;"></span