nsparent); transform: skewX(-15deg); transition: left 0.6s; pointer-events: none;"></div><div style="font-family: &quot;Cormorant Garamond&quot;, serif; font-size: clamp(26px, 4vw, 36px); font-weight: 700; color: rgb(68, 101, 89); line-height: 1; letter-spacing: -0.02em;">0+</div><div style="font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: rgb(90, 114, 104); margin-top: 7px;">Happy Eyes</div></div><div style="position: relative; background: rgb(248, 246, 241); border: 1px solid rgba(68, 101, 89, 0.14); border-radius: 16px; padding: 22px 14px 18px; text-align: center; overflow: hidden; cursor: default; transform: translateY(24px); opacity: 0; box-shadow: none; transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1) 470ms, box-shadow 0.35s, border-color 0.3s, opacity 0.6s;"><div style="position: absolute; top: 0px; left: 20%; right: 20%; height: 2px; background: linear-gradient(90deg, transparent, rgb(184, 151, 90), transparent); border-radius: 0px 0px 2px 2px; opacity: 0; transition: opacity 0.3s;"></div><div style="position: absolute; top: 0px; left: -70%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent); transform: skewX(-15deg); transition: left 0.6s; pointer-events: none;"></div><div style="font-family: &quot;Cormorant Garamond&quot;, serif; font-size: clamp(26px, 4vw, 36px); font-weight: 700; color: rgb(68, 101, 89); line-height: 1; letter-spacing: -0.02em;">0+</div><div style="font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: rgb(90, 114, 104); margin-top: 7px;">Years of Experience</div></div><div style="position: relative; background: rgb(248, 246, 241); border: 1px solid rgba(68, 101, 89, 0.14); border-radius: 16px; padding: 22px 14px 18px; text-align: center; overflow: hidden; cursor: default; transform: translateY(24px); opacity: 0; box-shadow: none; transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1) 590ms, box-shadow 0.35s, border-color 0.3s, opacity 0.6s;"><div style="position: absolute; top: 0px; left: 20%; right: 20%; height: 2px; background: linear-gradient(90deg, transparent, rgb(184, 151, 90), transparent); border-radius: 0px 0px 2px 2px; opacity: 0; transition: opacity 0.3s;"></div><div style="position: absolute; top: 0px; left: -70%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent); transform: skewX(-15deg); transition: left 0.6s; pointer-events: none;"></div><div style="font-family: &quot;Cormorant Garamond&quot;, serif; font-size: clamp(26px, 4vw, 36px); font-weight: 700; color: rgb(68, 101, 89); line-height: 1; letter-spacing: -0.02em;">0+</div><div style="font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: rgb(90, 114, 104); margin-top: 7px;">Eye Surgeries</div></div></div><button type="button" style="display: inline-flex; align-items: center; gap: 10px; margin-top: 32px; padding: 14px 32px; background-color: rgb(68, 101, 89); color: rgb(255, 255, 255); font-family: &quot;DM Sans&quot;, sans-serif; font-size: 14px; font-weight: 500; letter-spacing: 0.06em; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 8px; cursor: pointer; opacity: 0; transform: translateY(16px); transition: opacity 0.6s 0.5s, transform 0.6s 0.5s, background 0.2s;">Know More<span style="font-size: 18px; line-height: 1;">→</span></button></div><div style="position: relative; overflow: visible;"><div class="ab-ring-spin" style="position: absolute; top: -24px; right: -24px; width: 180px; height: 180px; border-radius: 50%; border: 1.5px dashed rgba(68, 101, 89, 0.2); pointer-events: none; z-index: 0;"></div><div class="ab-ring2-spin" style="position: absolute; bottom: -20px; left: -20px; width: 120px; height: 120px; border-radius: 50%; border: 1px solid rgba(184, 151, 90, 0.25); pointer-events: none; z-index: 0;"></div><div style="position: absolute; left: -20px; top: 20%; bottom: 20%; width: 2px; background: linear-gradient(transparent, rgb(184, 151, 90), transparent); border-radius: 2px;"></div><div class="ab-badge-bob" style="position: absolute; top: -18px; left: -18px; z-index: 10; width: 96px; height: 96px; border-radius: 50%; background: rgb(44, 68, 56); display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: rgba(44, 68, 56, 0.35) 0px 8px 28px; border: 3px solid rgb(255, 255, 255); box-sizing: border-box; padding: 4px; text-align: center;"><div style="font-family: &quot;Cormorant Garamond&quot;, serif; font-size: 26px; font-weight: 700; color: rgb(255, 255, 255); line-height: 1;">9+</div><div style="font-size: 8.5px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255, 255, 255, 0.85); margin-top: 2px; line-height: 1.15;">Years of<br>Trust</div></div><div style="position: relative; border-radius: 20px; overflow: hidden; z-index: 2;"><img alt="Zains Super Speciality Eye Hospital — Outside View" class="ab-img-hover" src="./m_files/shopOutSideImage1.png" style="width: 100%; aspect-ratio: 5 / 4; object-fit: cover; object-position: center center; display: block; border-radius: 20px; transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1); opacity: 0; transform: scale(0.97);"><div style="position: absolute; bottom: 0px; left: 0px; right: 0px; height: 40%; background: linear-gradient(to top, rgba(30, 42, 34, 0.55) 0%, transparent 100%); border-radius: 0px 0px 20px 20px; pointer-events: none;"></div></div><div class="ab-float-bob" style="position: absolute; bottom: -16px; right: -16px; z-index: 5; background: rgb(255, 255, 255); border-radius: 14px; padding: 14px 18px; display: flex; align-items: center; gap: 12px; box-shadow: rgba(68, 101, 89, 0.18) 0px 8px 32px; border: 1px solid rgba(68, 101, 89, 0.12);"><div style="width: 38px; height: 38px; border-radius: 10px; background: rgb(238, 245, 241); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;">🏆</div><div><div style="font-family: &quot;Cormorant Garamond&quot;, serif; font-size: 17px; font-weight: 700; color: rgb(26, 40, 32); line-height: 1;">50,000+</div><div style="font-size: 10px; color: rgb(90, 114, 104); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 3px; font-weight: 400;">Successful Surgeries</div></div></div></div></div></section><section class="relative overflow-hidden py-20 px-8" id="why-choose-us" style="background-color: rgb(247, 245, 240); font-family: &quot;DM Sans&quot;, sans-serif;"><div class="pointer-events-none absolute" style="width: 500px; height: 500px; top: -200px; right: -150px; border-radius: 50%; background: rgba(68, 101, 89, 0.06);"></div><div class="pointer-events-none absolute" style="width: 300px; height: 300px; bottom: -100px; left: -80px; border-radius: 50%; background: rgba(68, 101, 89, 0.06);"></div><div class="relative z-10 mx-auto grid max-w-6xl grid-cols-1 items-center gap-16 lg:grid-cols-2"><div><div class="mb-5 inline-flex items-center gap-2" style="color: rgb(68, 101, 89); font-size: 11px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase;"><span style="display: inline-block; width: 28px; height: 1.5px; background: rgb(68, 101, 89); flex-shrink: 0;"></span>Our Excellence</div><h2 class="mb-8 leading-tight tracking-tight" style="font-family: &quot;Cormorant Garamond&quot;, serif; font-size: clamp(36px, 4vw, 52px); font-weight: 600; color: rgb(30, 45, 39); line-height: 1.15;">Why Choose <em style="font-style: italic; color: rgb(68, 101, 89);">Zains Eye Hospital</em></h2><p class="mb-5" style="font-size: 15px; line-height: 1.75; color: rgb(74, 90, 82); font-weight: 300;">At Zains Eye Hospital, we combine modern ophthalmic technology with experienced specialists and personalized care — delivering the highest standards of vision care with a patient-first approach.</p><p class="mb-5" style="font-size: 15px; line-height: 1.75; color: rgb(74, 90, 82); font-weight: 300;">From routine examinations to advanced eye surgeries, every treatment is built around accuracy, safety, and long-term results. We believe quality eye care should be accessible to everyone across Kerala and beyond.</p><blockquote class="my-7" style="border-left: 2px solid rgb(68, 101, 89); padding: 16px 20px; background: rgba(68, 101, 89, 0.04); font-family: &quot;Cormorant Garamond&quot;, serif; font-size: 19px; line-height: 1.55; color: rgb(42, 61, 50); font-style: italic;">Your vision is our priority — we build trust through expert care, advanced technology, and a commitment to excellence at every stage of treatment.</blockquote><button style="display: inline-flex; align-items: center; gap: 12px; padding: 16px 36px; background-color: rgb(68, 101, 89); color: rgb(255, 255, 255); font-family: &quot;DM Sans&quot;, sans-serif; font-size: 15px; font-weight: 500; letter-spacing: 0.06em; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 6px; cursor: pointer;">Know More<span style="font-size: 20px; line-height: 1;">→</span></button></div><div class="flex flex-col gap-4"><div class="relative"><img alt="Consulting at Zains Eye Hospital" class="w-full object-cover" src="./m_files/consulting.webp" style="border-radius: 16px; max-height: 440px; aspect-ratio: 4 / 5;"></div><div class="flex items-start gap-4 rounded-xl bg-white p-4" style="border: 0.5px solid rgba(68, 101, 89, 0.15);"><div style="width: 36px; height: 36px; border-radius: 8px; background: rgb(238, 245, 241); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px;">👁</div><div><p style="font-size: 13px; font-weight: 500; color: rgb(30, 45, 39); margin: 0px 0px 3px;">Advanced Diagnostics</p><p style="font-size: 12px; color: rgb(122, 148, 136); margin: 0px; line-height: 1.5; font-weight: 300;">State-of-the-art imaging and diagnostic equipment for precise diagnosis</p></div></div><div class="flex items-start gap-4 rounded-xl bg-white p-4" style="border: 0.5px solid rgba(68, 101, 89, 0.15);"><div style="width: 36px; height: 36px; border-radius: 8px; background: rgb(238, 245, 241); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px;">🩺</div><div><p style="font-size: 13px; font-weight: 500; color: rgb(30, 45, 39); margin: 0px 0px 3px;">Expert Specialists</p><p style="font-size: 12px; color: rgb(122, 148, 136); margin: 0px; line-height: 1.5; font-weight: 300;">Experienced ophthalmologists with subspecialty training in all areas</p></div></div><div class="flex items-start gap-4 rounded-xl bg-white p-4" style="border: 0.5px solid rgba(68, 101, 89, 0.15);"><div style="width: 36px; height: 36px; border-radius: 8px; background: rgb(238, 245, 241); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px;">🤝</div><div><p style="font-size: 13px; font-weight: 500; color: rgb(30, 45, 39); margin: 0px 0px 3px;">Compassionate Care</p><p style="font-size: 12px; color: rgb(122, 148, 136); margin: 0px; line-height: 1.5; font-weight: 300;">Patient-centered approach with transparent, affordable treatment plans</p></div></div></div></div></section><section class="py-24 bg-white" id="patient-stories"><div class="max-w-7xl mx-auto px-6 lg:px-8"><div class="flex flex-col lg:flex-row gap-16 items-center"><div class="w-full lg:w-1/3 text-center lg:text-left"><h2 class="text-4xl md:text-5xl lg:text-[54px] font-bold mb-6 text-[#158f8b] leading-[1.1]" style="font-family: &quot;DM Sans&quot;, sans-serif; letter-spacing: -0.02em;">Our<br>Happy Patients</h2><p class="text-gray-600 mb-10 text-[17px] leading-relaxed max-w-sm mx-auto lg:mx-0">A short glimpse of our people's experience at Zains Eye Hospital and Clinic.</p><a href="https://zains-hospital.vercel.app/#testimonials" class="inline-block px-10 py-3.5 bg-[#a8674b] text-white font-medium rounded-full hover:bg-[#8f563d] transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5" style="font-family: &quot;DM Sans&quot;, sans-serif;">Explore</a></div><div class="w-full lg:w-2/3"><div class="grid grid-cols-1 sm:grid-cols-3 gap-5"><div class="col-span-1 sm:col-span-2 relative rounded-2xl overflow-hidden cursor-pointer group shadow-sm hover:shadow-xl transition-all duration-300 bg-gray-100 border border-gray-100"><img alt="Patient Story Thumbnail" class="w-full h-56 sm:h-48 md:h-64 object-cover transform group-hover:scale-[1.03] transition-transform duration-700 ease-in-out" src="./m_files/hqdefault.jpg"><div class="absolute inset-0 bg-black/5 group-hover:bg-black/10 transition-colors duration-300 flex items-end justify-start p-4 sm:p-5"><div class="w-10 h-10 sm:w-11 sm:h-11 bg-[#a8674b] rounded-full flex items-center justify-center shadow-lg transform group-hover:scale-110 transition-transform duration-300"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play text-white ml-0.5" aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg></div></div></div><div class="col-span-1 sm:col-span-1 relative rounded-2xl overflow-hidden cursor-pointer group shadow-sm hover:shadow-xl transition-all duration-300 bg-gray-100 border border-gray-100"><img alt="Patient Story Thumbnail" class="w-full h-56 sm:h-48 md:h-64 object-cover transform group-hover:scale-[1.03] transition-transform duration-700 ease-in-out" src="./m_files/hqdefault(1).jpg"><div class="absolute inset-0 bg-black/5 group-hover:bg-black/10 transition-colors duration-300 flex items-end justify-start p-4 sm:p-5"><div class="w-10 h-10 sm:w-11 sm:h-11 bg-[#a8674b] rounded-full flex items-center justify-center shadow-lg transform group-hover:scale-110 transition-transform duration-300"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play text-white ml-0.5" aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg></div></div></div><div class="col-span-1 sm:col-span-1 relative rounded-2xl overflow-hidden cursor-pointer group shadow-sm hover:shadow-xl transition-all duration-300 bg-gray-100 border border-gray-100"><img alt="Patient Story Thumbnail" class="w-full h-56 sm:h-48 md:h-64 object-cover transform group-hover:scale-[1.03] transition-transform duration-700 ease-in-out" src="./m_files/hqdefault(2).jpg"><div class="absolute inset-0 bg-black/5 group-hover:bg-black/10 transition-colors duration-300 flex items-end justify-start p-4 sm:p-5"><div class="w-10 h-10 sm:w-11 sm:h-11 bg-[#a8674b] rounded-full flex items-center justify-center shadow-lg transform group-hover:scale-110 transition-transform duration-300"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play text-white ml-0.5" aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg></div></div></div><div class="col-span-1 sm:col-span-2 relative rounded-2xl overflow-hidden cursor-pointer group shadow-sm hover:shadow-xl transition-all duration-300 bg-gray-100 border border-gray-100"><img alt="Patient Story Thumbnail" class="w-full h-56 sm:h-48 md:h-64 object-cover transform group-hover:scale-[1.03] transition-transform duration-700 ease-in-out" src="./m_files/hqdefault(3).jpg"><div class="absolute inset-0 bg-black/5 group-hover:bg-black/10 transition-colors duration-300 flex items-end justify-start p-4 sm:p-5"><div class="w-10 h-10 sm:w-11 sm:h-11 bg-[#a8674b] rounded-full flex items-center justify-center shadow-lg transform group-hover:scale-110 transition-transform duration-300"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play text-white ml-0.5" aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg></div></div></div></div></div></div></div></section><style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Jost:wght@300;400;500&display=swap');

        :root {
          --cm-green: #446559;
          --cm-green-dark: #2c4438;
          --cm-green-light: #eef5f1;
          --cm-gold: #b8975a;
          --cm-cream: #faf8f4;
          --cm-ink: #1e2a22;
          --cm-muted: #6b7e74;
        }

        @keyframes cm-slowDrift {
          0%,100% { transform: translate(0,0) scale(1); }
          50% { transform: translate(20px,-20px) scale(1.05); }
        }
        @keyframes cm-pulse {
          0%,100% { opacity:1; transform:scale(1); }
          50% { opacity:0.4; transform:scale(0.65); }
        }
        @keyframes cm-stampSpin {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
        @keyframes cm-stampSpinRev {
          from { transform: rotate(0deg); }
          to { transform: rotate(-360deg); }
        }
        @keyframes cm-fadeUp {
          from { opacity:0; transform:translateY(28px); }
          to { opacity:1; transform:translateY(0); }
        }

        .cm-stamp-ring { animation: cm-stampSpin 24s linear infinite; }
        .cm-stamp-inner-content { animation: cm-stampSpinRev 24s linear infinite; }
      </style><section id="chairman" style="width: 100%; background: var(--cm-cream, #faf8f4); padding: 72px 24px 88px; position: relative; overflow: hidden; font-family: Jost, sans-serif;"><div style="position: absolute; inset: 0px; pointer-events: none;"><div style="position: absolute; inset: 0px; background-image: repeating-linear-gradient(-45deg, transparent, transparent 40px, rgba(68, 101, 89, 0.024) 40px, rgba(68, 101, 89, 0.024) 41px);"></div><div style="position: absolute; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(68, 101, 89, 0.08) 0%, transparent 70%); top: -200px; right: -180px; animation: 14s ease-in-out 0s infinite normal none running cm-slowDrift;"></div><div style="position: absolute; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(184, 151, 90, 0.07) 0%, transparent 70%); bottom: -180px; left: -100px; animation: 18s ease-in-out 0s infinite reverse none running cm-slowDrift;"></div></div><div style="position: absolute; width: 40px; height: 40px; pointer-events: none; top: 20px; left: 20px; border-top: 1.5px solid rgb(184, 151, 90); border-left: 1.5px solid rgb(184, 151, 90);"></div><div style="position: absolute; width: 40px; height: 40px; pointer-events: none; top: 20px; right: 20px; border-top: 1.5px solid rgb(184, 151, 90); border-right: 1.5px solid rgb(184, 151, 90);"></div><div style="position: absolute; width: 40px; height: 40px; pointer-events: none; bottom: 20px; left: 20px; border-bottom: 1.5px solid rgb(184, 151, 90); border-left: 1.5px solid rgb(184, 151, 90);"></div><div style="position: absolute; width: 40px; height: 40px; pointer-events: none; bottom: 20px; right: 20px; border-bottom: 1.5px solid rgb(184, 151, 90); border-right: 1.5px solid rgb(184, 151, 90);"></div><div style="position: relative; z-index: 2; max-width: 1040px; margin: 0px auto;"><div style="display: flex; align-items: center; gap: 14px; margin-bottom: 40px; opacity: 0; transform: translateY(20px); transition: opacity 0.7s, transform 0.7s;"><div style="flex: 1 1 0%; height: 1px; background: linear-gradient(90deg, transparent, rgb(184, 151, 90), transparent);"></div><span style="font-size: 10px; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase; color: rgb(184, 151, 90);">Message from the Chairman</span><div style="flex: 1 1 0%; height: 1px; background: linear-gradient(90deg, transparent, rgb(184, 151, 90), transparent);"></div></div><div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); border-radius: 4px; overflow: hidden; box-shadow: rgba(30, 42, 34, 0.13) 0px 24px 80px, rgba(30, 42, 34, 0.07) 0px 4px 20px; opacity: 0; transform: translateY(32px); transition: opacity 0.8s 0.1s, transform 0.8s 0.1s;"><div style="position: relative; overflow: hidden; background: rgb(44, 68, 56); min-height: 420px;"><img alt="Hidayathulla P — Chairman &amp; MD, Zains Group" src="./m_files/mdImage.jpg.jpeg" style="width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; filter: saturate(0.9) contrast(1.05); transition: transform 0.9s cubic-bezier(0.23, 1, 0.32, 1);"><div style="position: absolute; bottom: 0px; left: 0px; right: 0px; height: 55%; background: linear-gradient(to top, rgba(30, 42, 34, 0.88) 0%, transparent 100%); pointer-events: none;"></div><div style="position: absolute; top: 0px; right: 0px; width: 3px; height: 100%; background: linear-gradient(transparent, rgb(184, 151, 90) 30%, rgb(184, 151, 90) 70%, transparent); opacity: 0.7;"></div><div style="position: absolute; bottom: 28px; left: 28px; right: 28px;"><div style="width: 32px; height: 1.5px; background: rgb(184, 151, 90); margin-bottom: 10px;"></div><div style="font-family: &quot;Playfair Display&quot;, serif; font-size: 22px; font-weight: 700; color: rgb(255, 255, 255); line-height: 1.15;">Hidayathulla P</div><div style="font-size: 11px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255, 255, 255, 0.6); margin-top: 5px;">Chairman &amp; Managing Director</div><div style="font-size: 10px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(184, 151, 90); margin-top: 8px;">Zains Group</div></div></div><div style="background: rgb(255, 255, 255); padding: clamp(28px, 5vw, 52px); display: flex; flex-direction: column; position: relative; overflow: hidden;"><div style="position: absolute; top: 0px; right: 0px; width: 200px; height: 200px; background-image: radial-gradient(circle, rgba(68, 101, 89, 0.12) 1px, transparent 1px); background-size: 18px 18px; opacity: 0.5; pointer-events: none;"></div><div aria-hidden="true" style="font-family: &quot;Playfair Display&quot;, serif; font-size: 120px; line-height: 0.6; color: rgba(68, 101, 89, 0.07); position: absolute; top: 44px; right: 44px; pointer-events: none; user-select: none; font-style: italic;">"</div><div style="display: inline-flex; align-items: center; gap: 9px; font-size: 10px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(68, 101, 89); margin-bottom: 16px;"><span style="width: 5px; height: 5px; border-radius: 50%; background: rgb(184, 151, 90); display: inline-block; animation: 2.5s ease 0s infinite normal none running cm-pulse;"></span>A Word from the Top</div><h2 style="font-family: &quot;Playfair Display&quot;, serif; font-size: clamp(28px, 4vw, 44px); font-weight: 400; color: rgb(30, 42, 34); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 6px;">The <em style="font-style: italic; color: rgb(68, 101, 89);">Chairman's</em><br>Message</h2><div style="display: flex; align-items: center; gap: 12px; margin: 20px 0px 28px;"><div style="height: 1px; width: 80px; background: linear-gradient(90deg, rgb(68, 101, 89) 0%, rgb(184, 151, 90) 60%, transparent 100%);"></div><div style="width: 6px; height: 6px; background: rgb(184, 151, 90); transform: rotate(45deg); flex-shrink: 0;"></div></div><p style="font-family: &quot;Playfair Display&quot;, serif; font-size: clamp(14px, 2.2vw, 17px); font-style: italic; color: rgb(68, 101, 89); line-height: 1.65; margin-bottom: 22px; padding-left: 18px; border-left: 2px solid rgb(184, 151, 90);">"Welcome to Zains Eye Hospital. Our mission is to provide trusted, high-quality eye care with compassion and excellence."</p><p style="font-size: 14.5px; color: rgb(107, 126, 116); line-height: 1.8; font-weight: 300; flex: 1 1 0%; margin-bottom: 36px;">We are committed to combining advanced technology, experienced medical professionals, and patient-centered care to help every individual achieve better vision and a better quality of life. At Zains, we believe that every patient deserves personal attention, ethical treatment, and the highest standards of healthcare.<br><br>I sincerely thank our patients, Doctors, staff, and well-wishers for their continued trust and support in our journey.</p><div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; padding-top: 24px; border-top: 1px solid rgba(68, 101, 89, 0.1); flex-wrap: wrap;"><div><svg width="110" height="28" viewBox="0 0 110 28" fill="none" style="display: block; margin-bottom: 8px; opacity: 0.55;"><path d="M4 22 C18 6, 28 26, 42 14 S66 4, 80 18 S96 28, 107 10" stroke="#446559" stroke-width="1.5" fill="none" stroke-linecap="round"></path></svg><div style="font-family: &quot;Playfair Display&quot;, serif; font-size: 17px; font-weight: 700; color: rgb(30, 42, 34); letter-spacing: -0.01em;">Hidayathulla P</div><div style="font-size: 11px; font-weight: 400; color: rgb(107, 126, 116); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 3px;">Chairman &amp; MD, Zains Group</div></div><div style="width: 68px; height: 68px; border-radius: 50%; border: 1.5px solid rgba(68, 101, 89, 0.25); display: flex; align-items: center; justify-content: center; position: relative; flex-shrink: 0;"><svg class="cm-stamp-ring" viewBox="0 0 68 68" style="position: absolute; inset: 0px